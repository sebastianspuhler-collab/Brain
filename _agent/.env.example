# Prozessia Brain — Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte aus

# Anthropic API Key (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Microsoft Azure (für Outlook-Kalender)
# Werte aus dem Azure Portal → App-Registrierungen
MS_CLIENT_ID=
MS_TENANT_ID=
MS_CLIENT_SECRET=

# Gmail OAuth wird beim ersten Start automatisch eingerichtet
# (Browser öffnet sich zur Google-Anmeldung)
