# =============================================================================
# Umgebungsvariablen – Schaufler Beschaffungsagent
# =============================================================================
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
# NIEMALS die .env Datei ins Git Repository committen!
# =============================================================================

# ---------------------------------------------------------------------------
# OpenAI API
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Microsoft Graph API (E-Mail-Adapter: graph)
# ---------------------------------------------------------------------------
GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GRAPH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GRAPH_USER_EMAIL=Order@schaufler.de

# ---------------------------------------------------------------------------
# IMAP E-Mail-Adapter (Alternative zu Graph)
# ---------------------------------------------------------------------------
IMAP_SERVER=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=Order@schaufler.de
IMAP_PASSWORD=xxxxxxxxxxxxxxxx
IMAP_USE_SSL=true

# ---------------------------------------------------------------------------
# ERP – Proleis / Winform
# ---------------------------------------------------------------------------
ERP_API_URL=https://erp.schaufler.de/api
ERP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ERP_API_TIMEOUT=30

# ---------------------------------------------------------------------------
# DMS – ELO
# ---------------------------------------------------------------------------
ELO_BASE_URL=https://elo.schaufler.de
ELO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELO_ARCHIV_ID=default

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------
DASHBOARD_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
