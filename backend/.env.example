# Vault-Pfad: Ordner, der Kunden/, Finanzen/, _agent/ etc. enthält.
VAULT_PATH=/root/Prozessia-Brain

# Von Anthropic Console, NIEMALS per Chat/WhatsApp verschicken.
ANTHROPIC_API_KEY=sk-ant-...

# Signiert Session-Cookies. Erzeugen mit: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Erlaubte Frontend-Origin für CORS (kein Wildcard mehr wie im alten Server).
# Auf dem VPS laufen Frontend und Backend hinter Traefik unter derselben Domain
# (Caddy proxied /api intern) - dann greift CORS ohnehin nicht, dieser Wert ist
# nur fürs lokale Dev-Setup relevant, wo Vite auf einem anderen Port läuft.
CORS_ORIGIN=https://brain.prozessia.space

# Wo die Benutzer-Datei liegt (JSON-Map {"username": "bcrypt-hash"}).
# BEWUSST eine Datei statt einer ENV-Variable: bcrypt-Hashes enthalten "$"-Zeichen,
# die docker-compose in env_file-Werten als Variablen-Interpolation missversteht
# und stillschweigend kaputt schreibt. Anlegen/aktualisieren mit:
#   python scripts/hash_password.py
USERS_FILE=./users.json
