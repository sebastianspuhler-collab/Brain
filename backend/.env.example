# Vault-Pfad: Ordner, der Kunden/, Finanzen/, _agent/ etc. enthält.
VAULT_PATH=/root/Prozessia-Brain

# Von Anthropic Console, NIEMALS per Chat/WhatsApp verschicken.
ANTHROPIC_API_KEY=sk-ant-...

# ── Claude-Engine: API-Key vs. Claude-Code-Abo (optional, 2026-07-22) ─────────
# "api" (Default, unverändertes Verhalten) = Anthropic Messages API mit
# ANTHROPIC_API_KEY, nutzungsabhängige Abrechnung. "cli" = `claude -p` als
# Subprocess (Claude-Code-Headless-Modus), Abrechnung über das Claude-Code-Abo
# statt pro Token. NUR auf "cli" umstellen, nachdem CLAUDE_CODE_OAUTH_TOKEN
# gesetzt und ein Testlauf bestätigt wurde - siehe app/services/claude_cli.py.
CLAUDE_ENGINE=api
# Einmalig erzeugen mit: claude setup-token (Browser-Login, öffnet
# claude.ai-Account-Bestätigung, gibt den Token in der Konsole aus). NIEMALS
# per Chat/WhatsApp verschicken, wie der Anthropic-API-Key auch.
CLAUDE_CODE_OAUTH_TOKEN=

# Signiert Session-Cookies. Erzeugen mit: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-to-a-long-random-string

# Erlaubte Frontend-Origin für CORS (kein Wildcard mehr wie im alten Server).
# Auf dem VPS laufen Frontend und Backend hinter Traefik unter derselben Domain
# (Caddy proxied /api intern) - dann greift CORS ohnehin nicht, dieser Wert ist
# nur fürs lokale Dev-Setup relevant, wo Vite auf einem anderen Port läuft.
CORS_ORIGIN=https://brain.prozessia.space

# Wo die Benutzer-Datei liegt (JSON-Map {"username": "bcrypt-hash"}).
# BEWUSST eine Datei statt einer ENV-Variable: bcrypt-Hashes enthalten "$"-Zeichen,
# die docker-compose in env_file-Werten als Variablen-Interpolation missversteht
# und stillschweigend kaputt schreibt. Anlegen/aktualisieren mit:
#   python scripts/hash_password.py
USERS_FILE=./users.json

# ── Google Workspace Integration (Gmail, Drive, Sheets) ───────────────────────
# 1. Service Account für Automation:
#    → https://console.cloud.google.com → IAM → Service Accounts → JSON-Key
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# 2. OAuth Credentials für User-Authentifizierung:
#    → https://console.cloud.google.com → APIs & Dienste → Credentials
#    → "OAuth 2.0 Client ID (Desktop App)" → JSON herunterladen
GOOGLE_CREDENTIALS_JSON={"installed": {"client_id": "...", "client_secret": "..."}}

# 3. Ordner-ID für Kundenordner (aus Google Drive URL)
DRIVE_KUNDEN_FOLDER_ID=...

# ── Microsoft 365 Integration (Outlook, Teams, Calendar) ────────────────────────
# Siehe auch: _agent/ms_setup.md für Schritt-für-Schritt Anleitung
# 1. Gehe zu https://portal.azure.com → App-Registrierungen
# 2. Neue Registrierung mit Name "Prozessia Brain"
MS_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MS_TENANT_ID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
MS_CLIENT_SECRET=

# ── LinkedIn / Buffer ─────────────────────────────────────────────────────────
# Buffer API Token (aus Buffer-Dashboard -> Developers -> Access Token)
BUFFER_API_TOKEN=...

# ── YouTube / Buffer ─────────────────────────────────────────────────────────
# Kanal-ID des mit Buffer verbundenen YouTube-Kanals. Buffer-Dashboard -> Kanal
# auswählen -> die ID steht in der URL (buffer.com/channels/<ID>/...).
BUFFER_CHANNEL_YOUTUBE=...
# Öffentliche Domain, unter der dieses Backend erreichbar ist (ohne Pfad).
# Buffer lädt hochgeladene Videos selbst von hier herunter - MUSS von außen
# erreichbar sein, sonst schlägt der Video-Push fehl. Fällt auf CORS_ORIGIN
# zurück, auf dem VPS also meist nicht extra nötig zu setzen.
PUBLIC_BASE_URL=https://brain.prozessia.space

# ── LinkedIn Karussell (Content-Engine: Slides → Bilder → PDF → Cloudinary) ────
# OpenAI API Key für gpt-image-1 (Slide-Bilder). Aus platform.openai.com.
OPENAI_API_KEY=sk-proj-...
# Cloudinary-Zugangsdaten für PDF-/Bild-Hosting (Buffer lädt das fertige
# Karussell von dort). Aus cloudinary.com Dashboard -> Account Details.
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ── OCR-Vorstufe für PDFs (optional, Umsetzungsplan-Memo 2026-07-16) ──────────
# Ohne diesen Key läuft die PDF-Extraktion wie bisher über PyPDF2 (kein
# Verhalten ändert sich). Mit Key: Mistral OCR liest gescannte/mehrspaltige
# PDFs zuverlässiger aus. Aus console.mistral.ai.
MISTRAL_API_KEY=...

# ── Git-Sync (Vault Mac ↔ VPS) ────────────────────────────────────────────────
# GitHub Personal Access Token (classic, Scope: repo) für automatisches
# git pull (alle 10 min) + git push nach Memory-Writes.
# Erzeugen unter: github.com/settings/tokens -> Generate new token (classic)
GIT_PAT=ghp_...

# ── GitHub / Onboarding-Automatisierung ───────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_ORG=Prozessia

# ── SMTP für Email-Benachrichtigungen ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...
NOTIFICATION_EMAIL=amin@prozessia.de

# ── Twenty CRM Integration (Leadfeeder-Export) ─────────────────────────────────
# GraphQL API URL der Twenty-Instanz
TWENTY_API_URL=https://your-twenty-instance.com/graphql
# Bearer Token für die Twenty API (aus Settings -> Developers -> API Tokens)
TWENTY_API_KEY=your_api_key_here

# ── Leadfeeder Bot ─────────────────────────────────────────────────────────────
# true = VPS/Docker (headless, nutzt gespeicherte Cookies)
# false = lokal (zeigt Browser-Dialoge für manuelles Login)
HEADLESS_MODE=false
